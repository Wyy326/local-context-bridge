{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Context Bridge",
  "version": "0.1.2",
  "identifier": "dev.local-context-bridge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Local Context Bridge",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "Local chat context bridge",
    "longDescription": "Move local TRAE SOLO CN chat context between local accounts without uploading data.",
    "copyright": "Copyright 2026 Local Context Bridge contributors",
    "license": "Apache-2.0",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": null,
        "installMode": "perMachine"
      }
    }
  }
}
